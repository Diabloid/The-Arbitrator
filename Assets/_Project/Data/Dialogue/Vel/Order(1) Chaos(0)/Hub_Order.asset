  m_Script: {fileID: 11500000, guid: 9379242b3f96bfc42ac1cb83e7ebdf3e, type: 3}
  m_Name: Hub_Order
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  speakerName: "\u041C\u0430\u043D\u0434\u0440\u0456\u0432\u043D\u0438\u043A"
  speakerColor: {r: 1, g: 1, b: 1, a: 1}
  speakerOutlineColor: {r: 0, g: 0, b: 0, a: 1}
  speakerOutlineWidth: 0.2
  npcText: "\u041E, \u044F \u0432\u0436\u0435 \u0431\u0430\u0447\u0443 \u0446\u044E
    \u0456\u0434\u0435\u0430\u043B\u044C\u043D\u0443 \u0437\u0432\u0456\u0442\u043D\u0456\u0441\u0442\u044C.
    \u0426\u0456\u043B\u044C \u043B\u0456\u043A\u0432\u0456\u0434\u043E\u0432\u0430\u043D\u0430,
    \u0437\u0430\u043C\u043E\u043A \u0432\u0456\u043B\u044C\u043D\u0438\u0439, \u0425\u0430\u043E\u0441
    \u043F\u0440\u0438\u0434\u0443\u0448\u0435\u043D\u043E. \u0417\u043D\u0430\u0454\u0448,
    \u0410\u0439\u0432\u0435\u043D, \u0437 \u0442\u043E\u0431\u043E\u044E \u043F\u0440\u0430\u0446\u044E\u0432\u0430\u0442\u0438
    \u043E\u0434\u043D\u0435 \u0437\u0430\u0434\u043E\u0432\u043E\u043B\u0435\u043D\u043D\u044F
    \u2014 \u043D\u0456\u044F\u043A\u0438\u0445 \u043F\u043E\u044F\u0441\u043D\u044E\u0432\u0430\u043B\u044C\u043D\u0438\u0445
    \u0437\u0430\u043F\u0438\u0441\u043E\u043A \u0456 \u0437\u0430\u0439\u0432\u043E\u0457
    \u043F\u0430\u043F\u0435\u0440\u043E\u0432\u043E\u0457 \u0442\u044F\u0433\u0430\u043D\u0438\u043D\u0438.
    \u0410\u043B\u0435 \u043F\u0430\u043C'\u044F\u0442\u0430\u0439 \u043D\u0430\u0448\u0443
    \u0440\u043E\u0437\u043C\u043E\u0432\u0443 \u043F\u0440\u043E \u0441\u0456\u0440\u0456
    \u0442\u043E\u043D\u0438... \u0421\u043C\u0435\u0440\u0442\u044C \u0446\u044C\u043E\u0433\u043E
    \u043D\u0435\u043A\u0440\u043E\u043C\u0430\u043D\u0442\u0430 \u043D\u0435 \u043D\u0430\u0433\u043E\u0434\u0443\u0454
    \u041D\u0438\u0436\u043D\u0454 \u043C\u0456\u0441\u0442\u043E. \u0429\u043E \u0436,
    \u043F\u0440\u0438\u043D\u0430\u0439\u043C\u043D\u0456 \u043C\u0456\u0439 \u0441\u0442\u0456\u043B
    \u0442\u0435\u043F\u0435\u0440 \u0432\u0456\u043B\u044C\u043D\u0438\u0439 \u0432\u0456\u0434
    \u0430\u043A\u0442\u0456\u0432. \u0417\u0430\u0431\u0438\u0440\u0430\u0439 \u043D\u0430\u0433\u043E\u0440\u043E\u0434\u0443."
  choices:
  - choiceText: "1. \u0420\u043E\u0431\u043E\u0442\u0443 \u0432\u0438\u043A\u043E\u043D\u0430\u043D\u043E,
      \u0412\u0435\u043B. \u0414\u0430\u0432\u0430\u0439 \u043F\u0440\u043E \u0456\u043D\u0448\u0435."
