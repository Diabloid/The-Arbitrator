  m_Script: {fileID: 11500000, guid: 9379242b3f96bfc42ac1cb83e7ebdf3e, type: 3}
  m_Name: Hub_Vel_Tutorial
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  speakerName: "\u0412\u0435\u043B"
  speakerColor: {r: 0.41568628, g: 0, b: 0.78431374, a: 1}
  speakerOutlineColor: {r: 0.2, g: 0.003921569, b: 0.3764706, a: 1}
  speakerOutlineWidth: 0.3
  npcText: "\u0421\u043B\u0443\u0445\u0430\u0439 \u0443\u0432\u0430\u0436\u043D\u043E.
    \u0422\u0432\u0456\u0439 \u043F\u0435\u0440\u0435\u043A\u0430\u0442 - \u0446\u0435
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043F\u043E\u0441\u0456\u0431
    \u0432\u0442\u0435\u043A\u0442\u0438. \u0423 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u0443
    \u043C\u0438\u0442\u044C \u0432\u0456\u043D \u0434\u043E\u0437\u0432\u043E\u043B\u044F\u0454
    \u043F\u0440\u043E\u0441\u043B\u0438\u0437\u043D\u0443\u0442\u0438 \u043A\u0440\u0456\u0437\u044C
    \u0441\u0430\u043C\u0443 \u0441\u043C\u0435\u0440\u0442\u044C \u2014 \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0439
    \u0439\u043E\u0433\u043E \u0437 \u0440\u043E\u0437\u0443\u043C\u043E\u043C. \u041A\u0430\u043C\u0435\u043D\u0456
    \u0437\u0446\u0456\u043B\u0435\u043D\u043D\u044F \u043D\u0435 \u043D\u0435\u0441\u043A\u0456\u043D\u0447\u0435\u043D\u043D\u0456.
    \u0406 \u0433\u043E\u043B\u043E\u0432\u043D\u0435: \u043F\u0435\u0440\u0435\u0434
    \u0442\u0438\u043C \u044F\u043A \u0432\u0438\u043D\u0435\u0441\u0442\u0438 \u0432\u0438\u0440\u043E\u043A
    \u0447\u0435\u0440\u0433\u043E\u0432\u0456\u0439 \u0446\u0456\u043B\u0456, \u043F\u0435\u0440\u0435\u043A\u043E\u043D\u0430\u0439\u0441\u044F,
    \u0449\u043E \u0440\u043E\u0437\u0443\u043C\u0456\u0454\u0448, \u0447\u043E\u043C\u0443
    \u0432\u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u0434\u0435\u0441\u0442\u0430\u0431\u0456\u043B\u0456\u0437\u0443\u044E\u0447\u043E\u044E.
    \u0421\u0432\u0456\u0442 \u043D\u0435 \u0434\u0456\u043B\u0438\u0442\u044C\u0441\u044F
    \u043B\u0438\u0448\u0435 \u043D\u0430 \u0447\u043E\u0440\u043D\u0435 \u0442\u0430
    \u0431\u0456\u043B\u0435."
  choices:
  - choiceText: "1. \u042F \u0437\u0430\u043F\u0430\u043C'\u044F\u0442\u0430\u044E.
      \u041F\u043E\u0432\u0435\u0440\u043D\u0435\u043C\u043E\u0441\u044C \u0434\u043E
      \u0441\u043F\u0440\u0430\u0432."
