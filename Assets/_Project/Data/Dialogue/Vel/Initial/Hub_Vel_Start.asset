  m_Script: {fileID: 11500000, guid: 9379242b3f96bfc42ac1cb83e7ebdf3e, type: 3}
  m_Name: Hub_Vel_Start
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  speakerName: "\u0412\u0435\u043B"
  speakerColor: {r: 0.41568628, g: 0, b: 0.78431374, a: 1}
  speakerOutlineColor: {r: 0.20020679, g: 0.005339969, b: 0.3773585, a: 1}
  speakerOutlineWidth: 0.3
  npcText: "\u0410, \u043D\u043E\u0432\u0438\u0439 \u0410\u0440\u0431\u0456\u0442\u0440...
    \u0410\u0439\u0432\u0435\u043D, \u0447\u0438 \u043D\u0435 \u0442\u0430\u043A?
    \u042F \u0412\u0435\u043B, \u043C\u0456\u0441\u0446\u0435\u0432\u0438\u0439 \u0456\u043D\u0442\u0435\u043D\u0434\u0430\u043D\u0442.
    \u041C\u043E\u044F \u0440\u043E\u0431\u043E\u0442\u0430 \u2014 \u0441\u0442\u0435\u0436\u0438\u0442\u0438,
    \u0449\u043E\u0431 \u0442\u0438 \u043D\u0435 \u0437\u0434\u043E\u0445 \u043D\u0430
    \u043F\u0435\u0440\u0448\u043E\u043C\u0443 \u0436 \u0437\u0430\u0432\u0434\u0430\u043D\u043D\u0456,
    \u0431\u043E \u043F\u0430\u043F\u0435\u0440\u043E\u0432\u043E\u0457 \u0442\u044F\u0433\u0430\u043D\u0438\u043D\u0438
    \u043F\u043E\u0442\u0456\u043C \u043D\u0435 \u043E\u0431\u0435\u0440\u0435\u0448\u0441\u044F.
    \u0427\u0438\u043C \u043C\u043E\u0436\u0443 \u0434\u043E\u043F\u043E\u043C\u043E\u0433\u0442\u0438?"
  choices:
  - choiceText: "1. \u0429\u043E \u0446\u0435 \u0437\u0430 \u043C\u0456\u0441\u0446\u0435?"
    nextNode: {fileID: 11400000, guid: db9c9cfc74d573b4d9a6682664cd6881, type: 2}
    actionId: 
  - choiceText: "2. \u041C\u0435\u043D\u0456 \u043F\u043E\u0442\u0440\u0456\u0431\u043D\u0430
      \u043F\u043E\u0440\u0430\u0434\u0430 \u0449\u043E\u0434\u043E \u0437\u0430\u0432\u0434\u0430\u043D\u044C."
    nextNode: {fileID: 11400000, guid: 844c3685839d8444b9da3e791392ba48, type: 2}
    actionId: 
  - choiceText: "3. \u0429\u043E \u0442\u0438 \u043C\u043E\u0436\u0435\u0448 \u043C\u0435\u043D\u0456
      \u0437\u0430\u043F\u0440\u043E\u043F\u043E\u043D\u0443\u0432\u0430\u0442\u0438?"
    nextNode: {fileID: 11400000, guid: 47ff48be5cba3f0419f5687e34f9e41b, type: 2}
    actionId: 
  - choiceText: "4. \u041F\u043E\u043A\u0438 \u043D\u0456\u0447\u043E\u0433\u043E.
      \u0411\u0443\u0432\u0430\u0439."
    nextNode: {fileID: 0}
    actionId: 
