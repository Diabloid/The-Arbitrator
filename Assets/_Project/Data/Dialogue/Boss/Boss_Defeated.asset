  m_Script: {fileID: 11500000, guid: 9379242b3f96bfc42ac1cb83e7ebdf3e, type: 3}
  m_Name: Boss_Defeated
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  speakerName: "\u041C\u043E\u0440\u0456\u0441"
  speakerColor: {r: 0.9150943, g: 0.03987401, b: 0, a: 1}
  speakerOutlineColor: {r: 0.509434, g: 0, b: 0, a: 1}
  speakerOutlineWidth: 0.3
  voiceSound: {fileID: 8300000, guid: 331220db22f971f4f93b6c2d9670efda, type: 3}
  voicePitch: 0.711
  npcText: "(\u0412\u0430\u0436\u043A\u043E \u0434\u0438\u0445\u0430\u0454, \u0441\u043F\u0438\u0440\u0430\u044E\u0447\u0438\u0441\u044C
    \u043D\u0430 \u0440\u043E\u0437\u0431\u0438\u0442\u0438\u0439 \u043F\u043E\u0441\u043E\u0445)\n\u041A\u0445\u0435...
    \u041E\u0442\u0436\u0435, \u041A\u0430\u043D\u0446\u0435\u043B\u044F\u0440\u0456\u044F
    \u043D\u0430\u0440\u0435\u0448\u0442\u0456 \u0441\u043F\u0443\u0441\u0442\u0438\u043B\u0430
    \u0441\u0432\u043E\u0433\u043E \u043B\u0430\u043D\u0446\u044E\u0433\u043E\u0432\u043E\u0433\u043E
    \u043F\u0441\u0430. \u0429\u043E \u0436, \u0442\u0438 \u043F\u0435\u0440\u0435\u043C\u0456\u0433,
    \u0410\u0440\u0431\u0456\u0442\u0440\u0435. \u0422\u0432\u0456\u0439 \u0431\u0435\u0437\u0434\u043E\u0433\u0430\u043D\u043D\u0438\u0439
    \u041F\u043E\u0440\u044F\u0434\u043E\u043A \u0442\u0440\u0456\u0443\u043C\u0444\u0443\u0454.
    \u0410\u043B\u0435 \u0437\u0430\u043F\u0430\u043C'\u044F\u0442\u0430\u0439...
    \u043C\u043E\u0457 \u043C\u0435\u0440\u0446\u0456 \u0441\u043F\u0443\u0441\u043A\u0430\u043B\u0438\u0441\u044F
    \u0432 \u043E\u0442\u0440\u0443\u0439\u043D\u0456 \u0448\u0430\u0445\u0442\u0438
    \u043B\u0438\u0448\u0435 \u0434\u043B\u044F \u0442\u043E\u0433\u043E, \u0449\u043E\u0431
    \u0434\u0456\u0442\u0438 \u0432 \u041D\u0438\u0436\u043D\u044C\u043E\u043C\u0443
    \u043C\u0456\u0441\u0442\u0456 \u043D\u0435 \u0432\u043C\u0438\u0440\u0430\u043B\u0438
    \u0437 \u0433\u043E\u043B\u043E\u0434\u0443. \u0422\u0432\u043E\u0457 \u0437\u0430\u043A\u043E\u043D\u0438
    \u0457\u0445 \u043D\u0435 \u043D\u0430\u0433\u043E\u0434\u0443\u044E\u0442\u044C.
    \u042F \u0440\u043E\u0431\u0438\u0432 \u0442\u0435, \u0449\u043E \u043C\u0430\u0432.
    \u0422\u0435\u043F\u0435\u0440 \u0440\u043E\u0431\u0438 \u0442\u0435, \u0437\u0430
    \u0447\u0438\u043C \u043F\u0440\u0438\u0439\u0448\u043E\u0432 \u0442\u0438. \u0412\u0438\u043D\u043E\u0441\u044C
    \u0441\u0432\u0456\u0439 \u0432\u0438\u0440\u043E\u043A."
  choices:
  - choiceText: "1. \u0417\u0430\u043A\u043E\u043D \u043D\u0435 \u043F\u0440\u0438\u0439\u043C\u0430\u0454
      \u0432\u0438\u043F\u0440\u0430\u0432\u0434\u0430\u043D\u044C, \u043A\u043E\u043B\u0438
      \u0439\u0434\u0435\u0442\u044C\u0441\u044F \u043F\u0440\u043E \u043D\u0435\u043A\u0440\u043E\u043C\u0430\u043D\u0442\u0456\u044E.
      \u0422\u0432\u0456\u0439 \u0425\u0430\u043E\u0441 \u043C\u0430\u0454 \u0431\u0443\u0442\u0438
      \u0432\u0438\u043A\u043E\u0440\u0456\u043D\u0435\u043D\u0438\u0439. [\u0412\u0438\u043A\u043E\u043D\u0430\u0442\u0438
      \u0432\u0438\u0440\u043E\u043A]"
    nextNode: {fileID: 11400000, guid: 7eec6507d28fe2f45860ef77cceb692c, type: 2}
    actionId: KillBoss
  - choiceText: "2. \u0406\u043C\u043F\u0435\u0440\u0456\u0457 \u043F\u043E\u0442\u0440\u0456\u0431\u0435\u043D
      \u0447\u0438\u0441\u0442\u0438\u0439 \u0437\u0430\u043C\u043E\u043A, \u0430
      \u043D\u0435 \u0442\u0432\u043E\u044F \u0433\u043E\u043B\u043E\u0432\u0430.
      \u0417\u0430\u0431\u0438\u0440\u0430\u0439\u0441\u044F \u0432 \u041D\u0438\u0436\u043D\u0454
      \u043C\u0456\u0441\u0442\u043E \u0456 \u0431\u0456\u043B\u044C\u0448\u0435
      \u043D\u0435 \u0442\u0440\u0430\u043F\u043B\u044F\u0439\u0441\u044F \u043C\u0435\u043D\u0456
      \u043D\u0430 \u043E\u0447\u0456. [\u041F\u043E\u043C\u0438\u043B\u0443\u0432\u0430\u0442\u0438]"
    nextNode: {fileID: 11400000, guid: 1e516144912f70842ab1b02feebfe740, type: 2}
    actionId: SpareBoss
